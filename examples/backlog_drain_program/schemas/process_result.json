{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "item_id": { "type": "string" },
    "status": { "type": "string", "enum": ["fixed", "skipped", "deferred"] },
    "summary": { "type": "string" },
    "files_changed": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["item_id", "status", "summary", "files_changed"]
}
